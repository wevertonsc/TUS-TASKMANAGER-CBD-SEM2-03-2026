@startuml test_pyramid
title Task Manager - Testing Pyramid

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam package {
    BorderColor #2E75B6
    FontColor #1F4E79
    FontStyle bold
}

skinparam class {
    BackgroundColor #FFFFFF
    BorderColor #2E75B6
    FontColor #1A1A1A
    ArrowColor #2E75B6
    AttributeFontSize 11
    StereotypeFontSize 10
}

skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F9A825
    FontSize 11
}

'-------------------------------------------------------------------
' LEVEL 5 - E2E
'-------------------------------------------------------------------
package "Level 5 - End-to-End / System  [4 tests]" #FFE0E0 {

    class TaskEndToEndTest <<@SpringBootTest\n@AutoConfigureMockMvc\n@ActiveProfiles("test")>> {
        .. Scenario: Full CRUD Lifecycle ..
        + fullTaskLifecycle_CreateReadUpdateDelete_ShouldSucceed()
        .. Scenario: Status Filter Workflow ..
        + statusFilterWorkflow_ShouldReturnCorrectSubsets()
        .. Scenario: Validation End-to-End ..
        + validation_ShouldRejectInvalidRequests_EndToEnd()
        .. Scenario: Structured Error Response ..
        + notFound_ShouldReturnStructuredErrorResponse()
    }

    note right of TaskEndToEndTest
      No mocks.
      Full Spring context + H2.
      Verifies complete workflows
      across all application layers.
    end note
}

