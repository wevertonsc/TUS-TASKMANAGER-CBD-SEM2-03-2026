'-------------------------------------------------------------------
' LEVEL 3 - Controller Slice
'-------------------------------------------------------------------
package "Level 3 - Controller Slice  [15 tests]" #FFFACD {

    class TaskControllerTest <<@WebMvcTest(TaskController.class)>> {
        .. Setup ..
        - mockMvc : MockMvc
        - taskService : TaskService <<@MockBean>>
        ..
        + createTask_ShouldReturnCreatedTask_WhenValidRequest()
        + createTask_ShouldReturnBadRequest_WhenInvalidTitle()
        + getAllTasks_ShouldReturnListOfTasks()
        + getTaskById_ShouldReturnTask_WhenExists()
        + updateTask_ShouldReturnUpdatedTask_WhenValidRequest()
        + updateTaskStatus_ShouldReturnUpdatedTask()
        + getTasksByStatus_ShouldReturnFilteredTasks()
        + deleteTask_ShouldReturnNoContent_WhenTaskExists()
    }

    class TaskControllerEdgeCaseTest <<@WebMvcTest(TaskController.class)>> {
        .. Setup ..
        - mockMvc : MockMvc
        - taskService : TaskService <<@MockBean>>
        ..
        + getTaskById_ShouldReturn404_WhenTaskNotFound()
        + updateTask_ShouldReturn404_WhenTaskNotFound()
        + deleteTask_ShouldReturn404_WhenTaskNotFound()
        + createTask_ShouldReturnBadRequest_WhenTitleIsNull()
        + createTask_ShouldReturnBadRequest_WhenTitleExceedsMaxLength()
        + getAllTasks_ShouldReturnEmptyArray_WhenNoTasksExist()
        + getTasksByStatus_ShouldReturnEmptyArray_WhenNoTasksMatchStatus()
    }

    note right of TaskControllerTest
      TaskService replaced by @MockBean.
      Web layer only.
      No JPA, no DB.
    end note
}

'-------------------------------------------------------------------
' LEVEL 2 - Repository Slice
'-------------------------------------------------------------------
package "Level 2 - Repository Slice  [11 tests]" #D5F0E0 {

    class TaskRepositoryTest <<@DataJpaTest>> {
        .. Setup ..
        - taskRepository : TaskRepository
        - entityManager : TestEntityManager
        ..
        + findByStatus_ShouldReturnTasksWithSpecificStatus()
        + findByTitleContainingIgnoreCase_ShouldReturnMatchingTasks()
        + findOverdueTasks_ShouldReturnTasksWithDueDatePassed()
        + shouldSaveAndRetrieveTask()
    }

    class TaskRepositoryEdgeCaseTest <<@DataJpaTest>> {
        .. Setup ..
        - taskRepository : TaskRepository
        - entityManager : TestEntityManager
        ..
        + findById_ShouldReturnEmpty_WhenTaskDoesNotExist()
        + findByStatus_ShouldReturnEmpty_WhenNoTasksHaveThatStatus()
        + findByTitleContainingIgnoreCase_ShouldBeCaseInsensitive()
        + findOverdueTasks_ShouldNotReturnCompletedTasks()
        + findOverdueTasks_ShouldReturnOnlyNonCompletedOverdueTasks()
        + deleteTask_ShouldRemoveTaskFromDatabase()
        + existsById_ShouldReturnFalse_WhenTaskDoesNotExist()
        + existsById_ShouldReturnTrue_WhenTaskExists()
    }

    note right of TaskRepositoryTest
      JPA slice only.
      H2 replaces PostgreSQL.
      TestEntityManager for fixtures.
      No web, no service beans.
    end note
}

'-------------------------------------------------------------------
' LEVEL 1 - Service Unit
'-------------------------------------------------------------------
package "Level 1 - Service Unit  [17 tests]" #D5E8F0 {

    class TaskServiceTest <<@ExtendWith(MockitoExtension.class)>> {
        .. Setup ..
        - taskRepository : TaskRepository <<@Mock>>
        - taskService : TaskServiceImpl <<@InjectMocks>>
        ..
        + createTask_ShouldReturnTaskResponse_WhenTaskIsCreated()
        + getAllTasks_ShouldReturnListOfTaskResponses()
        + getTaskById_ShouldReturnTaskResponse_WhenTaskExists()
        + getTaskById_ShouldThrowTaskNotFoundException_WhenTaskDoesNotExist()
        + updateTask_ShouldReturnUpdatedTaskResponse_WhenTaskExists()
        + updateTaskStatus_ShouldUpdateStatus_WhenTaskExists()
        + getTasksByStatus_ShouldReturnFilteredTasks()
        + deleteTask_ShouldDeleteTask_WhenTaskExists()
        + deleteTask_ShouldThrowTaskNotFoundException_WhenTaskDoesNotExist()
    }

    class TaskServiceEdgeCaseTest <<@ExtendWith(MockitoExtension.class)>> {
        .. Setup ..
        - taskRepository : TaskRepository <<@Mock>>
        - taskService : TaskServiceImpl <<@InjectMocks>>
        ..
        + createTask_ShouldSetStatusToPending_Regardless()
        + createTask_WithNullDescription_ShouldNotFail()
        + createTask_WithDueDate_ShouldPreserveDueDate()
        + getAllTasks_ShouldReturnEmptyList_WhenNoTasksExist()
        + updateTask_ShouldThrowTaskNotFoundException_WhenTaskDoesNotExist()
        + updateTask_ShouldNotChangeStatus_WhenUpdatingFields()
        + updateTaskStatus_ShouldThrowTaskNotFoundException_WhenTaskDoesNotExist()
        + updateTaskStatus_ToAllValidStatuses_ShouldSucceed()
        + getTasksByStatus_ShouldReturnEmptyList_WhenNoTasksMatchStatus()
    }

    note right of TaskServiceTest
      Pure Mockito.
      No Spring context loaded.
      Constructor injection via
      @InjectMocks.
    end note
}

